# MES Trading Intelligence System — Environment Variables
# Copy this file to .env and fill in your credentials.
# All keys are OPTIONAL — the app runs in simulated mode without them.

# ── AI Assistant (Claude) ────────────────────────────────
ANTHROPIC_API_KEY=

# ── Rithmic (live market data via AMP Futures) ───────────
RITHMIC_USER=
RITHMIC_PASSWORD=

# ── AMP Futures (account sync / trade import) ───────────
# Falls back to RITHMIC_USER/RITHMIC_PASSWORD if not set
AMP_USERNAME=
AMP_PASSWORD=

# ── News & Sentiment ────────────────────────────────────
# Finnhub: free tier at https://finnhub.io — used for news + dark pool
FINNHUB_KEY=

# Twitter/X API v2 bearer token (optional — for real-time tweet streaming)
TWITTER_BEARER_TOKEN=
